<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.controller.LoginController">
   <center>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Café Management System" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Separator prefWidth="200.0" />
            <VBox spacing="10.0">
               <children>
                  <Label text="Username:" />
                  <TextField fx:id="usernameField" promptText="Nhập username" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label text="Password:" />
                  <PasswordField fx:id="passwordField" promptText="Nhập password" />
               </children>
            </VBox>
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleLogin" prefWidth="100.0" text="Login" />
                  <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="100.0" text="Exit" />
               </children>
            </HBox>
            <Label fx:id="errorLabel" textFill="#ff0000" />
         </children>
         <padding>
            <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
